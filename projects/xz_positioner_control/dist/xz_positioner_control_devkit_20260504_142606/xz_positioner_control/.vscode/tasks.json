{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Dev Environment",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File scripts\\setup_dev_env.ps1"
    },
    {
      "label": "Run Demo",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m xz_control_ui.main"
    },
    {
